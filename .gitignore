# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# Capacitor (iOS native project — generated by `npx cap add ios` on a Mac)
/ios/App/Pods
/ios/App/build
/ios/App/Podfile.lock
/ios/DerivedData
/ios/App/App/public
.xcuserstate
*.xcuserdatad/
